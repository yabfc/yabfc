{
	"$ref": "#/definitions/ProfileInterface",
	"$schema": "http://json-schema.org/draft-07/schema#",
	"definitions": {
		"ProfileInterface": {
			"additionalProperties": false,
			"properties": {
				"id": {
					"type": "string"
				},
				"items": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"category": {
								"type": "string"
							},
							"id": {
								"type": "string"
							},
							"name": {
								"type": "string"
							},
							"stackSize": {
								"type": "number"
							},
							"type": {
								"enum": ["item", "fluid"],
								"type": "string"
							}
						},
						"required": ["id", "type", "category", "stackSize"],
						"type": "object"
					},
					"type": "array"
				},
				"machineEffects": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"available": {
								"type": "boolean"
							},
							"id": {
								"type": "string"
							},
							"modifiers": {
								"items": {
									"anyOf": [
										{
											"additionalProperties": false,
											"properties": {
												"id": {
													"enum": [
														"speed",
														"power",
														"consumption",
														"productivity",
														"pollution",
														"quality"
													],
													"type": "string"
												},
												"modifiable": {
													"const": false,
													"type": "boolean"
												},
												"name": {
													"type": "string"
												},
												"onlyOutputScales": {
													"type": "boolean"
												},
												"value": {
													"type": "number"
												},
												"valueScaling": {
													"const": "exponential",
													"type": "string"
												}
											},
											"required": ["id", "modifiable", "value"],
											"type": "object"
										},
										{
											"additionalProperties": false,
											"properties": {
												"id": {
													"enum": [
														"speed",
														"power",
														"consumption",
														"productivity",
														"pollution",
														"quality"
													],
													"type": "string"
												},
												"maxValue": {
													"type": "number"
												},
												"minValue": {
													"type": "number"
												},
												"modifiable": {
													"const": true,
													"type": "boolean"
												},
												"name": {
													"type": "string"
												},
												"onlyOutputScales": {
													"type": "boolean"
												},
												"valueScaling": {
													"const": "exponential",
													"type": "string"
												}
											},
											"required": ["id", "maxValue", "minValue", "modifiable"],
											"type": "object"
										}
									]
								},
								"type": "array"
							},
							"name": {
								"type": "string"
							},
							"perSlot": {
								"type": "boolean"
							}
						},
						"required": ["id", "available", "modifiers", "perSlot"],
						"type": "object"
					},
					"type": "array"
				},
				"machines": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"available": {
								"type": "boolean"
							},
							"features": {
								"items": {
									"additionalProperties": false,
									"properties": {
										"disables": {
											"items": {
												"type": "string"
											},
											"type": "array"
										},
										"effectPerSlot": {
											"items": {
												"type": "string"
											},
											"type": "array"
										},
										"hidden": {
											"type": "boolean"
										},
										"id": {
											"type": "string"
										},
										"itemSlots": {
											"type": "number"
										},
										"name": {
											"type": "string"
										}
									},
									"required": ["id", "itemSlots", "effectPerSlot"],
									"type": "object"
								},
								"type": "array"
							},
							"id": {
								"type": "string"
							},
							"limitations": {
								"items": {
									"type": "string"
								},
								"type": "array"
							},
							"name": {
								"type": "string"
							},
							"recipeCategories": {
								"items": {
									"type": "string"
								},
								"type": "array"
							},
							"requiredPower": {
								"type": "number"
							}
						},
						"required": ["id", "available", "recipeCategories", "requiredPower", "features"],
						"type": "object"
					},
					"type": "array"
				},
				"name": {
					"type": "string"
				},
				"recipes": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"available": {
								"type": "boolean"
							},
							"category": {
								"type": "string"
							},
							"craftable": {
								"type": "boolean"
							},
							"duration": {
								"type": "number"
							},
							"id": {
								"type": "string"
							},
							"in": {
								"items": {
									"additionalProperties": false,
									"properties": {
										"amount": {
											"type": "number"
										},
										"id": {
											"type": "string"
										}
									},
									"required": ["id", "amount"],
									"type": "object"
								},
								"type": "array"
							},
							"limitations": {
								"items": {
									"type": "string"
								},
								"type": "array"
							},
							"name": {
								"type": "string"
							},
							"out": {
								"items": {
									"additionalProperties": false,
									"properties": {
										"amount": {
											"type": "number"
										},
										"id": {
											"type": "string"
										}
									},
									"required": ["id", "amount"],
									"type": "object"
								},
								"type": "array"
							},
							"priority": {
								"type": "number"
							}
						},
						"required": ["id", "available", "in", "out", "duration", "category", "priority"],
						"type": "object"
					},
					"type": "array"
				},
				"research": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"id": {
								"type": "string"
							},
							"name": {
								"type": "string"
							},
							"prerequisites": {
								"items": {
									"type": "string"
								},
								"type": "array"
							},
							"unlocks": {
								"items": {
									"additionalProperties": false,
									"properties": {
										"ids": {
											"items": {
												"type": "string"
											},
											"type": "array"
										},
										"type": {
											"const": "recipe",
											"type": "string"
										}
									},
									"required": ["type", "ids"],
									"type": "object"
								},
								"type": "array"
							}
						},
						"required": ["id", "unlocks"],
						"type": "object"
					},
					"type": "array"
				},
				"settings": {
					"additionalProperties": false,
					"properties": {
						"allRecipesUnlocked": {
							"type": "boolean"
						},
						"defaultDuration": {
							"type": "number"
						},
						"limitations": {
							"items": {
								"type": "string"
							},
							"type": "array"
						}
					},
					"required": ["defaultDuration", "allRecipesUnlocked"],
					"type": "object"
				}
			},
			"required": [
				"id",
				"name",
				"items",
				"recipes",
				"machines",
				"machineEffects",
				"research",
				"settings"
			],
			"type": "object"
		}
	}
}
