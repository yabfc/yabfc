{
	"$ref": "#/definitions/Profile",
	"$schema": "http://json-schema.org/draft-07/schema#",
	"definitions": {
		"Profile": {
			"additionalProperties": false,
			"properties": {
				"id": {
					"type": "string"
				},
				"items": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"category": {
								"type": "string"
							},
							"id": {
								"type": "string"
							},
							"name": {
								"type": "string"
							},
							"stackSize": {
								"type": "number"
							},
							"type": {
								"enum": ["item", "fluid"],
								"type": "string"
							}
						},
						"required": ["id", "type", "category", "stackSize"],
						"type": "object"
					},
					"type": "array"
				},
				"machineEffects": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"id": {
								"type": "string"
							},
							"modifiers": {
								"items": {
									"additionalProperties": false,
									"properties": {
										"id": {
											"type": "string"
										},
										"modifiable": {
											"type": "boolean"
										},
										"name": {
											"type": "string"
										},
										"onlyOutputScales": {
											"type": "boolean"
										},
										"value": {
											"type": "number"
										},
										"valueScaling": {
											"const": "exponential",
											"type": "string"
										}
									},
									"required": ["id", "value", "modifiable"],
									"type": "object"
								},
								"type": "array"
							},
							"name": {
								"type": "string"
							},
							"perSlot": {
								"type": "boolean"
							}
						},
						"required": ["id", "modifiers", "perSlot"],
						"type": "object"
					},
					"type": "array"
				},
				"machines": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"features": {
								"items": {
									"additionalProperties": false,
									"properties": {
										"effectPerSlot": {
											"items": {
												"type": "string"
											},
											"type": "array"
										},
										"id": {
											"type": "string"
										},
										"itemSlots": {
											"type": "number"
										},
										"name": {
											"type": "string"
										}
									},
									"required": ["id", "itemSlots", "effectPerSlot"],
									"type": "object"
								},
								"type": "array"
							},
							"id": {
								"type": "string"
							},
							"name": {
								"type": "string"
							},
							"recipeCategories": {
								"items": {
									"type": "string"
								},
								"type": "array"
							},
							"requiredPower": {
								"type": "number"
							}
						},
						"required": ["id", "recipeCategories", "requiredPower", "features"],
						"type": "object"
					},
					"type": "array"
				},
				"name": {
					"type": "string"
				},
				"recipes": {
					"items": {
						"additionalProperties": false,
						"properties": {
							"category": {
								"type": "string"
							},
							"duration": {
								"type": "number"
							},
							"id": {
								"type": "string"
							},
							"in": {
								"items": {
									"additionalProperties": false,
									"properties": {
										"amount": {
											"type": "number"
										},
										"id": {
											"type": "string"
										},
										"type": {
											"enum": ["item", "fluid"],
											"type": "string"
										}
									},
									"required": ["id", "type", "amount"],
									"type": "object"
								},
								"type": "array"
							},
							"name": {
								"type": "string"
							},
							"out": {
								"items": {
									"additionalProperties": false,
									"properties": {
										"amount": {
											"type": "number"
										},
										"id": {
											"type": "string"
										},
										"type": {
											"enum": ["item", "fluid"],
											"type": "string"
										}
									},
									"required": ["id", "type", "amount"],
									"type": "object"
								},
								"type": "array"
							}
						},
						"required": ["id", "in", "out", "duration", "category"],
						"type": "object"
					},
					"type": "array"
				}
			},
			"required": ["id", "name", "items", "recipes", "machines", "machineEffects"],
			"type": "object"
		}
	}
}
