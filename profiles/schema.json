{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/yabfc/yabfc/refs/heads/main/profiles/schema.json",
  "$defs": {
    "logistic-transport": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "throughput": {
          "type": "integer",
          "description": "per minute"
        }
      },
      "required": [
        "name",
        "throughput"
      ]
    },
    "logistics": {
      "type": "object",
      "properties": {
        "available_conveyor_belts": {
          "type": "array",
          "description": "should be used if mods are used",
          "items": {
            "$ref": "#/$defs/logistic-transport"
          }
        },
        "available_pipes": {
          "type": "array",
          "description": "should be used if mods are used",
          "items": {
            "$ref": "#/$defs/logistic-transport"
          }
        }
      }
    },
    "satisfactory-limitations": {
      "type": "object",
      "properties": {
        "unlocked_milestones": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unlocked_alternate_recipes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "overclocking_unlocked": {
          "type": "boolean"
        },
        "summerslooping_unlocked": {
          "type": "boolean"
        },
        "required": [
          "unlocked_milestones",
          "unlocked_alternate_recipes",
          "overclocking_unlocked",
          "summerslooping_unlocked"
        ]
      }
    },
    "factorio-limitations": {}
  },
  "title": "YABFC Satisfactory Schema",
  "type": "object",
  "properties": {
	"title": {
		"type": "string"
	},
	"description": {
		"type": "string"
	},
    "type": {
      "enum": [
        "satisfactory",
        "factorio"
      ]
    },
    "limitations": {
      "$ref": "#/$defs/logistics"
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "in": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "amount": {
                  "type": "integer"
                }
              }
            },
            "minItems": 1
          },
          "out": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "amount": {
                  "type": "integer"
                }
              }
            },
            "minItems": 1
          },
          "duration": {
            "type": "integer"
          },
          "produced_in": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "required": [
          "in",
          "out",
          "duration",
          "produced_in"
        ]
      }
    }
  },
  "if": {
    "properties": {
      "type": {
        "const": "satisfactory"
      }
    }
  },
  "then": {
    "properties": {
      "limitations": {
        "$ref": "#/$defs/satisfactory-limitations"
      }
    }
  }
}