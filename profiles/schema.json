{
	"$schema": "todo",
	"$id": "todo",
	"title": "YABFC Satisfactory Schema",
	"type": "object",
	"properties": {
		"type": {
			"const": "satisfactory"
		},
		"limitations": {
			"type": "object",
			"properties": {
				"unlocked_milestones": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"unlocked_alternate_recipes": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"overclocking_unlocked": {
					"type": "boolean"
				},
				"summerslooping_unlocked": {
					"type": "boolean"
				},
				"available_conveyoer_belts": {
					"type": "array",
					"description": "should be used if mods are used",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string"
							},
							"throughput": {
								"type": "integer",
								"description": "per minute"
							}
						},
						"required": ["name", "throughput"]
					}
				},
				"available_pipes": {
					"type": "array",
					"description": "should be used if mods are in use",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string"
							},
							"throughput": {
								"type": "integer",
								"description": "per minute"
							}
						},
						"required": ["name", "throughput"]
					}
				}
			},
			"required": [
				"unlocked_milestones",
				"unlocked_alternate_recipes",
				"overcklocking_unlocked",
				"summerslooping_unlocked"
			]
		},
		"recipes": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"in": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": {
									"type": "string"
								},
								"amount": {
									"type": "integer"
								}
							}
						},
						"minItems": 1
					},
					"out": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": {
									"type": "string"
								},
								"amount": {
									"type": "integer"
								}
							}
						},
						"minItems": 1
					},
					"duration": {
						"type": "integer"
					},
					"produced_in": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"minItems": 1
					}
				},
				"required": ["in", "out", "duration", "produced_in"]
			}
		}
	}
}
