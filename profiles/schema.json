{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://raw.githubusercontent.com/yabfc/yabfc/refs/heads/main/profiles/schema.json",
	"$defs": {
		"recipe-io": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string"
					},
					"amount": {
						"type": "number"
					},
					"type": { "type": "string", "enum": ["item", "fluid"] }
				},
				"required": ["name", "amount"]
			},
			"minItems": 1
		},
		"logistic-transport": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string"
				},
				"throughput": {
					"type": "number"
				},
				"duration": {
					"type": "number",
					"description": "(in seconds)"
				}
			},
			"required": ["name", "throughput", "duration"]
		},
		"logistics": {
			"type": "object",
			"properties": {
				"available_conveyor_belts": {
					"type": "array",
					"description": "should be used if mods are used",
					"items": {
						"$ref": "#/$defs/logistic-transport"
					}
				},
				"available_pipes": {
					"type": "array",
					"description": "should be used if mods are used",
					"items": {
						"$ref": "#/$defs/logistic-transport"
					}
				}
			}
		},
		"satisfactory-limitations": {
			"type": "object",
			"properties": {
				"unlocked_milestones": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"unlocked_alternate_recipes": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"overclocking": {
					"type": "boolean"
				},
				"summerslooping": {
					"type": "boolean"
				}
			},
			"required": [
				"unlocked_milestones",
				"unlocked_alternate_recipes",
				"overclocking",
				"summerslooping"
			]
		},
		"factorio-limitations": {
			"type": "object",
			"properties": {
				"unlocked_research": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"spaceage": {
					"type": "boolean"
				}
			},
			"required": ["unlocked_research", "spaceage"]
		}
	},
	"title": "YABFC Satisfactory Schema",
	"type": "object",
	"properties": {
		"title": {
			"type": "string"
		},
		"description": {
			"type": "string"
		},
		"type": {
			"enum": ["satisfactory", "factorio"]
		},
		"limitations": {
			"$ref": "#/$defs/logistics"
		},
		"recipes": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"in": {
						"$ref": "#/$defs/recipe-io"
					},
					"out": {
						"$ref": "#/$defs/recipe-io"
					},
					"duration": {
						"type": "number"
					},
					"produced_in": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"minItems": 1
					}
				},
				"required": ["in", "out", "duration", "produced_in"]
			}
		}
	},
	"if": {
		"properties": {
			"type": {
				"const": "satisfactory"
			}
		}
	},
	"then": {
		"properties": {
			"limitations": {
				"$ref": "#/$defs/satisfactory-limitations"
			}
		}
	},
	"else": {
		"properties": {
			"limitations": {
				"$ref": "#/$defs/factorio-limitations"
			}
		}
	}
}
