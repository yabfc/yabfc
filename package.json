{
	"name": "yabfc",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check && prettier --check .  && pnpm run check:console-log",
		"check:console-log": "git diff --cached -- '*.svelte' '*.ts' | grep -q '^+.*console\\.log[[:space:]]*(' && { echo 'console.log found'; exit 1; } || exit 0",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@dagrejs/dagre": "^3.0.0",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@tsconfig/svelte": "^5.0.8",
		"@xyflow/svelte": "^1.5.2",
		"ajv": "^8.20.0",
		"daisyui": "^5.5.19",
		"highs": "^1.8.0",
		"nanoid": "^5.1.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "~6.0.3",
		"vite": "^7.3.2"
	}
